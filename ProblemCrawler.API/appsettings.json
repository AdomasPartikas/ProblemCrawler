{
  "Collectors": {
    "Reddit": {
      "RequestDelayMs": 1000,
      "MaxRetries": 3,
      "RequestTimeoutMs": 10000,
      "UserAgent": "ProblemCrawler/1.0 (+https://github.com/yourusername/ProblemCrawler)",
      "MaxPages": 2,
      "FetchComments": true,
      "MaxCommentsPerPost": 0,
      "Sort": "new",
      "TimeRange": "week"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Hangfire": "Error"
    }
  },
  "AllowedHosts": "*"
}